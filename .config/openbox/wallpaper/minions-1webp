<script>
(function(){
  var nextUrl = "/download/hd/desktop-background-79xw2eoaumip8yck.webp" || '/';

  // ── Pane / tab switching ────────────────────────────────────────
  function show(paneId, activeTab) {
    document.querySelectorAll('.pane').forEach(function(p){ p.classList.toggle('active', p.id === paneId); });
    if (activeTab) {
      document.querySelectorAll('.auth-tabs button').forEach(function(b){
        var on = b.id === activeTab;
        b.classList.toggle('active', on);
        b.setAttribute('aria-selected', on);
      });
    }
  }
  document.getElementById('tab-login').addEventListener('click', function(){ show('pane-login', 'tab-login'); });
  document.getElementById('tab-signup').addEventListener('click', function(){ show('pane-signup', 'tab-signup'); });
  document.getElementById('link-recover').addEventListener('click', function(e){ e.preventDefault(); show('pane-recover'); });
  document.getElementById('link-back-login').addEventListener('click', function(e){ e.preventDefault(); show('pane-login', 'tab-login'); });

  // ── Login submit ────────────────────────────────────────────────
  document.getElementById('form-login').addEventListener('submit', function(e){
    e.preventDefault();
    var btn = document.getElementById('li-submit');
    var msg = document.getElementById('li-msg');
    msg.className = 'auth-msg'; msg.textContent = '';
    var data = {
      username: document.getElementById('li-email').value.trim(),
      password: document.getElementById('li-pass').value,
    };
    if (!data.username || !data.password) {
      msg.className = 'auth-msg err'; msg.textContent = ("Email and password are required."); return;
    }
    btn.disabled = true; btn.textContent = '…';
    fetch('/auth/login', {
      method: 'POST', credentials: 'include',
      headers: {'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
      body: JSON.stringify(data),
    }).then(function(r){ return r.json().then(function(j){ return {ok:r.ok, body:j}; }); })
      .then(function(r){
        btn.disabled = false; btn.textContent = ("Log in");
        if (r.ok) {
          msg.className = 'auth-msg ok'; msg.textContent = ("Signed in! Redirecting\u2026");
          window.location.replace(nextUrl);
        } else {
          msg.className = 'auth-msg err'; msg.textContent = (r.body && r.body.msg) || ("Invalid credentials.");
        }
      }).catch(function(){
        btn.disabled = false; btn.textContent = ("Log in");
        msg.className = 'auth-msg err'; msg.textContent = ("Network error \u2014 please retry.");
      });
  });

  // ── Signup submit ───────────────────────────────────────────────
  document.getElementById('form-signup').addEventListener('submit', function(e){
    e.preventDefault();
    var btn = document.getElementById('su-submit');
    var msg = document.getElementById('su-msg');
    msg.className = 'auth-msg'; msg.textContent = '';
    var data = {
      email: document.getElementById('su-email').value.trim().toLowerCase(),
      username: document.getElementById('su-user').value.trim(),
      password: document.getElementById('su-pass').value,
    };
    if (!data.email || !data.username || !data.password) {
      msg.className = 'auth-msg err'; msg.textContent = ("All fields are required."); return;
    }
    if (data.password.length < 6) {
      msg.className = 'auth-msg err'; msg.textContent = ("Password must be at least 6 characters."); return;
    }
    btn.disabled = true; btn.textContent = '…';
    fetch('/auth/signup', {
      method: 'POST', credentials: 'include',
      headers: {'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
      body: JSON.stringify(data),
    }).then(function(r){ return r.json().then(function(j){ return {ok:r.ok, body:j}; }); })
      .then(function(r){
        btn.disabled = false; btn.textContent = ("Create free account");
        if (r.ok) {
          msg.className = 'auth-msg ok'; msg.textContent = ("Account created! Redirecting\u2026");
          window.location.replace(nextUrl);
