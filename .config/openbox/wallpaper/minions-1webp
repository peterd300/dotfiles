        btn.disabled = false; btn.textContent = ("Create free account");
        msg.className = 'auth-msg err'; msg.textContent = ("Network error \u2014 please retry.");
      });
  });

  // ── Recover submit — POST to /auth/customer/reset ──────────────
  document.getElementById('form-recover').addEventListener('submit', function(e){
    e.preventDefault();
    var btn = document.getElementById('rc-submit');
    var msg = document.getElementById('rc-msg');
    msg.className = 'auth-msg'; msg.textContent = '';
    var email = document.getElementById('rc-email').value.trim().toLowerCase();
    if (!email) {
      msg.className = 'auth-msg err'; msg.textContent = ("Email is required."); return;
    }
    btn.disabled = true; btn.textContent = '…';
    fetch('/auth/customer/reset', {
      method: 'POST', credentials: 'include',
      headers: {'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
      body: JSON.stringify({email: email}),
    }).then(function(r){ return r.json().catch(function(){ return {}; }); })
      .then(function(){
        // Always succeed-style — endpoint never confirms whether the email
        // exists (anti-enumeration).
        btn.disabled = false; btn.textContent = ("Send reset link");
        msg.className = 'auth-msg ok';
        msg.textContent = ("If that email is registered, you\u0027ll receive a reset link shortly.");
      }).catch(function(){
        btn.disabled = false; btn.textContent = ("Send reset link");
        msg.className = 'auth-msg err';
        msg.textContent = ("Network error \u2014 please retry.");
      });
