  // silently suppressed by FedCM/3p-cookie rules and made the button look
  // dead). We poll until the GIS SDK (async) is ready, then render Google's
  // own button into #g-btn and hide the placeholder.
  
  (function initGoogle(tries){
    if (window.google && google.accounts && google.accounts.id) {
      google.accounts.id.initialize({
        client_id: "44812929862-e7k4js1kqb7rdft9m4d2ke2hiov95290.apps.googleusercontent.com",
        ux_mode: 'popup',
        callback: function(data){
          fetch('/auth/oauth/google', {
            method: 'POST', credentials: 'include',
            headers: {'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
            body: JSON.stringify(data),
          }).then(function(r){
            if (r.ok) window.location.replace(nextUrl);
            else r.json().then(function(j){ alert((j && j.msg) || "Google sign-in failed."); })
                         .catch(function(){ alert("Google sign-in failed."); });
          });
        },
      });
      var host = document.getElementById('g-btn');
      if (host) {
        google.accounts.id.renderButton(host, {
          type: 'standard', theme: 'outline', size: 'large',
          text: 'continue_with', shape: 'rectangular',
          logo_alignment: 'left', width: Math.min(host.offsetWidth || 320, 400),
        });
        var placeholder = document.getElementById('btn-google');
        if (placeholder) placeholder.style.display = 'none';
      }
      return;
    }
    if (tries > 0) setTimeout(function(){ initGoogle(tries - 1); }, 200);  // ~10s
  })(50);
  

  // ── Facebook OAuth (FB.login) ───────────────────────────────────
  
  var fbBtn = document.getElementById('btn-facebook');
