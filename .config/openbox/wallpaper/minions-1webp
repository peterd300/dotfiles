<style>
  /* Login owns the entire viewport — the minimal-chrome header strip
     (top-left logo) and footer (© Terms · Privacy · Contact) from
     base_minimal.html are hidden so the hero gradient runs edge-to-edge. */
  body.login .min-header,
  body.login .min-foot { display: none !important; }
  body.login { background: #fff; }

  /* 70/30 split — hero panel on the left, form card on the right.
     Below 880px the hero collapses and the form takes the full width.
     min-height:100vh now that the minimal header/footer are hidden. */
  .auth-shell {
    display: grid; grid-template-columns: minmax(0, 1.6fr) minmax(380px, 1fr);
    gap: 0; min-height: 100vh;
  }
  /* Hero background — warm cream → sky blue gradient that fully covers
     the left/non-form region. Slightly deeper stops than the original so
     it reads as an intentional brand panel, not a near-white wash. */
  /* Legacy wp-main wraps `<main>` with a `main aside { max-width: 22rem; }`
     rule (built for the GDPR sidebar). Without these overrides the grid
     cell stays wide but the aside element itself clamps to 22rem, leaving
     a grey gap between the gradient and the form. */
  main .auth-hero, .auth-hero {
    background: linear-gradient(135deg, #fde68a 0%, #fef3c7 30%, #bae6fd 75%, #7dd3fc 100%);
    color: #1f2937; padding: 3.25rem 3rem; display: flex; flex-direction: column;
    position: relative; overflow: hidden;
    width: 100% !important; max-width: none !important;
    align-self: stretch; justify-self: stretch;
  }
  .auth-hero::before {
    content: ""; position: absolute; inset: 0;
    background:
      radial-gradient(circle at 80% 10%, rgba(251,191,36,.35), transparent 50%),
      radial-gradient(circle at 10% 90%, rgba(56,189,248,.30), transparent 45%);
    pointer-events: none;
  }
  .auth-hero-content {
    position: relative; z-index: 1;
    width: 100%; max-width: 520px; min-width: 0;
    margin: auto 0;
  }
  .auth-hero h2 {
    font-size: clamp(1.65rem, 2.2vw + 1rem, 2.1rem);
    line-height: 1.15; margin: 0 0 .85rem; color: #111827;
    word-break: break-word; hyphens: auto;
  }
  .auth-hero p  { color: #475569; font-size: 1.05rem; line-height: 1.55; margin: 0 0 1.5rem; max-width: 100%; }
  .auth-hero ul { list-style: none; padding: 0; margin: 0; display: grid; gap: .55rem; }
  .auth-hero li { display: flex; align-items: flex-start; gap: .6rem; color: #1f2937; font-size: .95rem; }
  .auth-hero li::before {
    content: "✓"; width: 22px; height: 22px; flex-shrink: 0;
    border-radius: 50%; background: rgba(31,41,55,.08); color: #d97706;
    display: inline-flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: .85rem;
  }

  .auth-side { padding: 3rem 2.25rem; display: flex; flex-direction: column;
                justify-content: center; background: #fff; }
  .auth-wrap { width: 100%; max-width: 420px; margin: 0 auto; padding: 0; }
  .auth-card { background: transparent; border: 0; border-radius: 0; padding: 0; box-shadow: none; }

  /* Single logo IMG (the full Logo.svg, same as the nav uses), scaled
     small. No extra wordmark text — Logo.svg already contains it. The
     prior version used the fav-icon + a hand-written "Wallpapers.com"
     wordmark, which read inconsistently with the nav. */
  .auth-logo {
    display: inline-flex; align-items: center;
    margin-bottom: 1.5rem;
    text-decoration: none;
  }
  .auth-logo img {
    height: 30px; width: auto; display: block;
  }
  /* Hero-side logo gets a much bigger treatment — it's the brand
     anchor of the page. Form-side logo stays compact (30px). */
  .auth-hero .auth-logo img { height: 60px; }
  .auth-hero .auth-logo { margin-bottom: 2.25rem; }

  @media (max-width: 880px) {
    .auth-shell { grid-template-columns: 1fr; min-height: 0; }
    /* Mobile: the login/signup FORM goes first (top), the colorful gradient +
       brand text sits BELOW it. Reorder the grid items and show the hero with
       lighter mobile padding instead of hiding it. */
    .auth-side { order: 1; padding: 2rem 1.25rem; }
    .auth-hero {
      display: flex !important;
      order: 2;
      padding: 2.25rem 1.5rem;
      min-height: 0;
      border-radius: 18px 18px 0 0;
    }
    .auth-hero .auth-logo { display: none; }   /* form side already has the logo */
    .auth-hero h2 { font-size: 1.5rem; }
  }
  .auth-tabs {
    display: flex; gap: .25rem; padding: .3rem;
    background: #f3f4f6; border-radius: 999px;
    margin-bottom: 1.5rem;
  }
  .auth-tabs button {
    flex: 1 1 0; padding: .55rem; border: none; background: transparent;
    border-radius: 999px; font-weight: 700; font-size: .92rem;
    color: #6b7280; cursor: pointer; transition: background .15s, color .15s;
  }
  .auth-tabs button.active { background: #1f2937; color: #fff; }

  .auth-oauth {
    display: flex; flex-direction: column; gap: .55rem;
    margin-bottom: 1.25rem;
  }
  /* OAuth buttons — slightly more visible than the previous flat white.
     Subtle grey body + darker hairline border so they read as real
     interactive surfaces, not "is that a button or a divider?". */
  .oauth-btn {
    display: flex; align-items: center; justify-content: center; gap: .55rem;
    width: 100%; padding: .8rem 1rem; border-radius: 10px;
    border: 1.5px solid #d1d5db; background: #f9fafb;
    font-weight: 700; font-size: .95rem; color: #1f2937;
    cursor: pointer; text-decoration: none;
    transition: background .12s, border-color .12s, box-shadow .12s;
  }
  .oauth-btn:hover {
    background: #fff; border-color: #9ca3af;
    box-shadow: 0 1px 2px rgba(0,0,0,.04);
    color: #1f2937;
  }
  .oauth-btn img { width: 18px; height: 18px; }

  .auth-divider {
    display: flex; align-items: center; gap: .75rem;
    color: #9ca3af; font-size: .8rem; margin: 1rem 0;
  }
  .auth-divider::before, .auth-divider::after {
    content: ''; flex: 1 1 auto; height: 1px; background: #e5e7eb;
  }

  .auth-field { margin-bottom: .85rem; }
  .auth-field label {
    display: block; font-size: .85rem; font-weight: 600;
    color: #374151; margin-bottom: .35rem;
  }
  .auth-field input {
    width: 100%; padding: .7rem .85rem;
    border: 1px solid #d1d5db; border-radius: 8px;
    font-size: .95rem; color: #1f2937; background: #fff;
    box-sizing: border-box;
  }
  .auth-field input:focus { outline: none; border-color: #2464c4; }

  .auth-row { display: flex; align-items: center; justify-content: space-between;
              font-size: .82rem; margin: -.25rem 0 1rem; }
  .auth-row a { color: #2464c4; text-decoration: none; }

  .auth-submit {
    width: 100%; padding: .85rem; border: none;
    background: #2464c4; color: #fff; border-radius: 10px;
    font-weight: 800; font-size: 1rem; cursor: pointer;
  }
  .auth-submit:hover { background: #1d4ed8; }
  .auth-submit:disabled { opacity: .55; cursor: not-allowed; }

  .auth-msg { font-size: .85rem; margin-top: .75rem; min-height: 1.2em; text-align: center; }
  .auth-msg.err { color: #dc2626; }
  .auth-msg.ok  { color: #15803d; }

  .auth-foot { text-align: center; color: #6b7280; font-size: .85rem; margin-top: 1rem; }
  .auth-foot a { color: #2464c4; text-decoration: none; font-weight: 600; }
  .auth-terms { color: #9ca3af; font-size: .72rem; text-align: center;
                margin-top: 1rem; line-height: 1.45; }
  .auth-terms a { color: #6b7280; }

  /* Pane swap — CSS Grid trick: all panes share grid cell 1/1, so the
     wrapper takes the height of the TALLEST pane. Inactive panes are
     hidden via visibility (kept in layout flow → no height jump when
     switching Sign up ↔ Log in). */
  .pane-stack { display: grid; }
  .pane-stack > .pane {
    grid-area: 1 / 1;
    visibility: hidden; pointer-events: none;
    opacity: 0; transition: opacity .12s ease;
  }
  .pane-stack > .pane.active {
    visibility: visible; pointer-events: auto;
    opacity: 1;
  }
  /* Legacy: outside the stack, fall back to display:none for non-active. */
  .pane:not(.active):not(.pane-stack > .pane) { display: none; }
</style>

